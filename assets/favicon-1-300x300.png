/* GRAVITY FORM SETTINGS -
errors, validations, etc..*/
/* this only targets gform_widget
from WordPress */
.gform_widget {
.gform_wrapper {
 /* hide previous button */
   .gform_previous_button {
  display: none !important;
 }
 /* hide required text label */
 .gform_required_legend {
   display: none !important;
 }
/* loader style */
 .gform-loader {
    width: 10px;
    height: 10px;
    border-block-end-color: var(--fl-global-primary);
    border-block-start-color: var(--fl-global-secondary);
    border-inline-end-color:var(--fl-global-secondary);
    border-inline-start-color: var(--fl-global-primary);
}
 /* hide long validation error */
 .gform_validation_errors {
   display: none;
 }
 .gfield_validation_message {
   background-color: #F5CCD6;
   color: #BB254B;
   padding: 6px 16px;
   position: absolute;
   max-width: 576px;
   @media screen and (max-width:768px) {position: relative;}
 }
 .gfield_error {
   input::placeholder {
     color: red;
   }
   input {
       border: 1px solid red !important;
   }
 }
 /* hide validation instruction */
  .instruction {
   display: none;
 }
 }
 }
 /*==/ GRAVITY FORM SETTINGS /==*/		</style>
